{
  "compilerOptions": {
    "strict": true,
    "moduleDetection": "force",
    "types": ["node"],
    "moduleResolution": "NodeNext",
    "module": "NodeNext",
    "paths": {
      "#utils/*": ["./src/utils/*"],
      "#templates/*": ["./src/templates/*"],
      "#functions/*": ["./src/functions/*"]
    }
  }
}
